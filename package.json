{
  "name": "parse-server-schema-manager",
  "version": "2.1.2",
  "description": "Parse server schema manager",
  "main": "index.js",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "build": "babel src -d dist --extensions \".ts,.js\" --copy-files",
    "make": "tsc",
    "type-check": "tsc",
    "test": "bun test --preload ./test/hooks.js --timeout 50000 --max-concurrency=1 test/integration",
    "coverage": "bun test --preload ./test/hooks.js --timeout 50000 --max-concurrency=1 --coverage --coverage-reporter=lcov test/integration",
    "lint": "eslint src/index.ts",
    "ci": "bun run coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vahidalizad/parse-server-schema-manager"
  },
  "author": "Vahid Alizad",
  "license": "ISC",
  "keywords": [
    "parse-server",
    "javascript",
    "backend",
    "CLP",
    "DBML",
    "schema",
    "schema-as-code"
  ],
  "homepage": "https://github.com/vahidalizad/parse-server-schema-manager",
  "peerDependencies": {
    "parse": ">=6 <9"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@typescript-eslint/parser": "^8.59.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "detect-port": "^2.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "parse": "^8.6.0",
    "parse-server": "^9.9.0",
    "typescript": "^6.0.3",
    "@types/bun": "^1.3.13",
    "yargs": "^18.0.0"
  }
}
